	color: #1E50A2;
	font-weight: 500;
}

/* й”ҷиҜҜжҸҗзӨә */
.error-tip {
	display: flex;
	align-items: center;
	padding: 20rpx 24rpx;
	background-color: #FFF1F0;
	border-radius: 12rpx;
	margin-bottom: 24rpx;
	border-left: 4rpx solid #FF4D4F;
}

.error-icon {
	font-size: 32rpx;
	margin-right: 12rpx;
}

.error-text {
	flex: 1;
	font-size: 26rpx;
	color: #FF4D4F;
}

/* жҸҗдәӨжҢүй’® */
.submit-btn {
	width: 100%;
	height: 88rpx;
	line-height: 88rpx;
	background-color: #1E50A2;
	color: #ffffff;
	font-size: 32rpx;
	font-weight: bold;
	border-radius: 44rpx;
	border: none;
	box-shadow: 0 8rpx 20rpx rgba(30, 80, 162, 0.3);
}

