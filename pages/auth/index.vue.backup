<template>
	<view class="auth-page">
		<view class="auth-container">
			<!-- ж ҮйўҳеҢ?-->
			<view class="auth-header">
				<view class="header-icon">рҹҺ“</view>
				<text class="header-title">иә«д»Ҫи®ӨиҜҒ</text>
				<text class="header-desc">иҜ·еЎ«еҶҷжӮЁзҡ„зңҹе®һдҝЎжҒҜе®ҢжҲҗи®ӨиҜ?/text>
			</view>

			<!-- иЎЁеҚ•еҢ?-->
			<view class="form-section">
				<!-- е§“еҗҚ -->
				<view class="form-item">
					<view class="form-label">
						<text class="label-text">е§“еҗҚ</text>
						<text class="label-required">*</text>
					</view>
					<input 
						class="form-input" 
						v-model="form.name" 
						placeholder="иҜ·иҫ“е…Ҙзңҹе®һе§“еҗ?
						placeholder-class="input-placeholder"
						@input="onNameInput"
					/>
				</view>

				<!-- еӯҰеҸ·/е·ҘеҸ· -->
				<view class="form-item">
					<view class="form-label">
						<text class="label-text">еӯҰеҸ·/е·ҘеҸ·</text>
						<text class="label-required">*</text>
					</view>
					<input 
						class="form-input" 
						v-model="form.studentId" 
						placeholder="иҜ·иҫ“е…ҘеӯҰеҸ·жҲ–е·ҘеҸ·"
						placeholder-class="input-placeholder"
						type="idcard"
						@input="onIdInput"
					/>
				</view>

				<!-- иә«д»Ҫзұ»еһӢ -->
				<view class="form-item">
					<view class="form-label">
						<text class="label-text">иә«д»Ҫзұ»еһӢ</text>
						<text class="label-required">*</text>
					</view>
					<view class="type-selector">
						<view 
							class="type-item" 
							:class="{ 'type-active': form.userType === 'student' }"
							@click="selectUserType('student')"
						>
							<text class="type-icon">рҹ‘ЁвҖҚрҹҺ?/text>
							<text class="type-text">еӯҰз”ҹ</text>
						</view>
						<view 
							class="type-item" 
							:class="{ 'type-active': form.userType === 'teacher' }"
							@click="selectUserType('teacher')"
						>
							<text class="type-icon">рҹ‘ЁвҖҚрҹҸ?/text>
							<text class="type-text">ж•ҷиҒҢе·?/text>
						</view>
					</view>
				</view>

				<!-- й”ҷиҜҜжҸҗзӨә -->
				<view class="error-tip" v-if="errorMsg">
					<text class="error-icon">вҡ пёҸ</text>
					<text class="error-text">{{ errorMsg }}</text>
				</view>

				<!-- жҸҗдәӨжҢүй’® -->
				<button 
					class="submit-btn" 
					:disabled="submitting"
					@click="onSubmit"
				>
					<text v-if="submitting">жҸҗдәӨдё?..</text>
					<text v-else>жҸҗдәӨи®ӨиҜҒ</text>
				</button>
			</view>

			<!-- иҜҙжҳҺеҢ?-->
			<view class="notice-section">
				<view class="notice-title">и®ӨиҜҒиҜҙжҳҺ</view>
				<text class="notice-item">1. иҜ·еЎ«еҶҷзңҹе®һжңүж•Ҳзҡ„иә«д»ҪдҝЎжҒҜ</text>
				<text class="notice-item">2. еӯҰеҸ·/е·ҘеҸ·дё?-12дҪҚж•°еӯ?/text>
				<text class="notice-item">3. и®ӨиҜҒдҝЎжҒҜе°Ҷз”ЁдәҺйў„зәҰйӘҢиҜ?/text>
				<text class="notice-item">4. еҰӮжңүз–‘й—®иҜ·иҒ”зі»е®ўжң?/text>
			</view>
		</view>
	</view>
</template>

<script>
import userApi from '@/api/user.js'

export default {
	data() {
		return {
			form: {
				name: '',
				studentId: '',
				userType: 'student'
			},
			errorMsg: '',
			submitting: false
		}
	},
	
	methods: {
		// е§“еҗҚиҫ“е…Ҙ
		onNameInput(e) {
			this.form.name = e.detail.value
			this.errorMsg = ''
		},
		
		// еӯҰеҸ·иҫ“е…Ҙ
		onIdInput(e) {
			// еҸӘе…Ғи®ёж•°еӯ—е’Ңеӯ—жҜҚ
			let value = e.detail.value.replace(/[^\w]/g, '')
			this.form.studentId = value
			this.errorMsg = ''
		},
		
		// йҖүжӢ©иә«д»Ҫзұ»еһӢ
		selectUserType(type) {
			this.form.userType = type
		},
		
		// иЎЁеҚ•йӘҢиҜҒ
		validateForm() {
			const { name, studentId } = this.form
			
			// йӘҢиҜҒе§“еҗҚ
			if (!name || name.trim().length < 2) {
				this.errorMsg = 'иҜ·иҫ“е…ҘжӯЈзЎ®зҡ„е§“еҗҚ(иҮіе°‘2дёӘеӯ—з¬?'
				return false
			}
			
			// йӘҢиҜҒеӯҰеҸ·/е·ҘеҸ·
			if (!studentId || studentId.length < 6) {
				this.errorMsg = 'иҜ·иҫ“е…ҘжӯЈзЎ®зҡ„еӯҰеҸ·/е·ҘеҸ·(иҮіе°‘6дҪ?'
				return false
			}
			
			return true
		},
		
		// жҸҗдәӨи®ӨиҜҒ
		async onSubmit() {
			// йӘҢиҜҒиЎЁеҚ•
			if (!this.validateForm()) {
				return
			}
			
			this.submitting = true
			this.errorMsg = ''
			
			try {
				// и°ғз”Ёи®ӨиҜҒAPI
				await userApi.authenticate(this.form)
				
				uni.showToast({
					title: 'и®ӨиҜҒжҲҗеҠҹ',
					icon: 'success'
				})
				
				// е»¶иҝҹиҝ”еӣһ
				setTimeout(() => {
					uni.navigateBack()
				}, 1500)
				
			} catch (error) {
				this.errorMsg = error.message || 'и®ӨиҜҒеӨұиҙҘ,иҜ·йҮҚиҜ?
				uni.showToast({
					title: 'и®ӨиҜҒеӨұиҙҘ',
					icon: 'none'
				})
			} finally {
				this.submitting = false
			}
		}
	}
}
</script>

<style scoped>
